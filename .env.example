NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://user:password@localhost:5432/database_name?schema=public"

BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:5000

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email configuration
EMAIL_SENDER_SMTP_USER=your_email@gmail.com
EMAIL_SENDER_SMTP_PASS=your_app_password
EMAIL_SENDER_SMTP_HOST=smtp.gmail.com
EMAIL_SENDER_SMTP_PORT=465
EMAIL_SENDER_SMTP_FROM=your_email@gmail.com
CONTACT_RECEIVER_EMAIL=your_email@gmail.com

# Google OAuth configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Admin Seed Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password123
ADMIN_NAME=Admin

# Cloudinary Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# IPInfo Token
IPINFO_TOKEN=your_ipinfo_token_here

# Chatbot Rate Limit (hardcoded — dashboard থেকে change হয় না)
# RATE_LIMIT = per window এ max request
# RATE_LIMIT_WINDOW = window duration in seconds
CHATBOT_RATE_LIMIT=10
CHATBOT_RATE_LIMIT_WINDOW=60

# JWT configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=30d