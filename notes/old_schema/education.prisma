model Education {
  id          String    @id @default(uuid())
  degree      String
  institution String
  board       String?
  startDate   DateTime
  endDate     DateTime?
  result      String?
  group       String?
  // grade       String?
  // description String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("educations")
}
