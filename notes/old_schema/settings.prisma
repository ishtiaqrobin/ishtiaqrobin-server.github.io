model Settings {
    id String @id @default(uuid())

    // Social Links
    linkedinUrl  String?
    githubUrl    String?
    facebookUrl  String?
    instagramUrl String?

    resumeLink     String?
    contactEmail   String?
    contactPhone   String?
    whatsappNumber String?

    address      String?
    availability String?
    experience   String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("settings")
}
