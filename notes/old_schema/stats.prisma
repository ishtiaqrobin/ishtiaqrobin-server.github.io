model Stats {
    id           String   @id @default(uuid())
    experience   Int?     @default(0)
    projects     Int?     @default(0)
    happyClients Int?     @default(0)
    successRate  Int?     @default(0)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@map("stats")
}
