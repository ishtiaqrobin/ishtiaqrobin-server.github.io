// About Model — SINGLETON
// id = 'singleton' fixed। upsert({ where: { id: 'singleton' }, ... }) ব্যবহার করতে হবে।
model About {
    id         String  @id @default("singleton")
    heroImg    String?
    aboutMeImg String?

    title       String?
    subtitle    String?
    description String? @db.Text
    resumeUrl   String?

    // Resume download tracking
    resumeDownloadCount Int @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("about")
}
