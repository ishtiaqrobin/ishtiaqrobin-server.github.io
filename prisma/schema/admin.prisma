// AdminProfile Model
// Single admin হওয়ায় এটা User এর সাথে 1-to-1 relation।
// Skill এর সাথে কোনো relation নেই — Skill সরাসরি Category এর under এ থাকে।
model AdminProfile {
    id        String   @id @default(uuid())
    userId    String   @unique
    bio       String?  @db.Text
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@map("admin_profile")
}
