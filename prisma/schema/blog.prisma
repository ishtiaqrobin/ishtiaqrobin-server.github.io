// Blog Post Model
model Blog {
    id          String     @id @default(uuid())
    title       String
    slug        String     @unique // URL-friendly: "my-first-post"
    excerpt     String?    @db.Text // Short preview text
    content     String     @db.Text // Full post content (Markdown / HTML)
    thumbnail   String?
    status      BlogStatus @default(DRAFT)
    isFeatured  Boolean    @default(false)
    publishedAt DateTime?  // null হলে draft হিসেবে থাকবে

    // SEO
    metaTitle       String?
    metaDescription String?

    // Stats
    viewCount Int @default(0)
    likeCount Int @default(0)

    // Relations
    tags     BlogTag[]
    comments BlogComment[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("blogs")
}

// Blog Tag Model
model BlogTag {
    id   String @id @default(uuid())
    name String @unique
    slug String @unique

    blogs Blog[]

    createdAt DateTime @default(now())

    @@map("blog_tags")
}

// Blog Comment Model (public users comment করতে পারবে)
model BlogComment {
    id      String  @id @default(uuid())
    name    String  // commenter name (guest হলে)
    email   String  // commenter email
    comment String  @db.Text
    
    isApproved Boolean @default(false) // Admin approve করার আগে দেখাবে না
    ipAddress  String? // spam prevention

    blogId String
    blog   Blog   @relation(fields: [blogId], references: [id], onDelete: Cascade)

    // Reply support (nested comment, 1 level)
    parentId String?
    parent   BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id])
    replies  BlogComment[] @relation("CommentReplies")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("blog_comments")
}