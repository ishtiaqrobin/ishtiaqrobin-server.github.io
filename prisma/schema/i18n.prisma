// Translation Model
// Multi-language support (EN + BN) এর জন্য।
// key = "hero.title", locale = "bn", value = "আমি ইশতিয়াক রবিন"
model Translation {
    id     String @id @default(uuid())
    key    String // "hero.title", "about.bio", "nav.home"
    locale String // "en", "bn"
    value  String @db.Text

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([key, locale]) // একই key এর জন্য একটাই locale থাকবে
    @@index([locale])
    @@map("translations")
}
