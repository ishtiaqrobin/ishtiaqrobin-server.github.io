// Settings Model — SINGLETON
// সবসময় একটাই row থাকবে। id = 'singleton' fixed।
// Service layer-এ upsert({ where: { id: 'singleton' }, ... }) ব্যবহার করতে হবে।
model Settings {
    id String @id @default("singleton")

    // Social Links
    linkedinUrl  String?
    githubUrl    String?
    contactEmail String?
    facebookUrl  String?

    // Contact info
    resumeLink     String?
    whatsappNumber String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("settings")
}
