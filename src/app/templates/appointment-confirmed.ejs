<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Appointment Confirmed - Ishtiaq Robin</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8fafc;
            color: #1e293b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 40px 20px;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
        }

        .header {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 800;
        }

        .header .badge {
            display: inline-block;
            margin-top: 10px;
            padding: 6px 14px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 999px;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .content {
            padding: 32px 30px;
        }

        .greeting {
            font-size: 16px;
            color: #334155;
            margin-bottom: 20px;
        }

        .details {
            background-color: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 12px;
            padding: 20px;
            margin: 20px 0;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            font-weight: 600;
            color: #64748b;
            font-size: 14px;
        }

        .detail-value {
            color: #0f172a;
            font-weight: 500;
            font-size: 14px;
            text-align: right;
        }

        .cta {
            text-align: center;
            margin: 30px 0 10px;
        }

        .cta a {
            display: inline-block;
            padding: 14px 32px;
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            color: #fff !important;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
        }

        .note {
            background-color: #fef3c7;
            border-left: 4px solid #f59e0b;
            padding: 14px 16px;
            border-radius: 8px;
            font-size: 13px;
            color: #78350f;
            margin-top: 20px;
        }

        .footer {
            padding: 20px 30px 32px;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            border-top: 1px solid #e2e8f0;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>✓ Appointment Confirmed</h1>
                <span class="badge">CONFIRMED</span>
            </div>
            <div class="content">
                <p class="greeting">
                    Hi <strong>
                        <%= name %>
                    </strong>,
                </p>
                <p>Great news! Your appointment with <strong>Ishtiaq Robin</strong> has been confirmed. Here are your
                    booking details:</p>

                <div class="details">
                    <div class="detail-row">
                        <span class="detail-label">Topic</span>
                        <span class="detail-value">
                            <%= topic %>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Date</span>
                        <span class="detail-value">
                            <%= date %>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Time</span>
                        <span class="detail-value">
                            <%= time %>
                        </span>
                    </div>
                    <% if (typeof adminNote !=='undefined' && adminNote) { %>
                        <div class="detail-row">
                            <span class="detail-label">Note</span>
                            <span class="detail-value">
                                <%= adminNote %>
                            </span>
                        </div>
                        <% } %>
                </div>

                <% if (typeof meetLink !=='undefined' && meetLink) { %>
                    <div class="cta">
                        <a href="<%= meetLink %>" target="_blank">Join Meeting</a>
                    </div>
                    <p style="text-align:center; font-size:12px; color:#64748b; word-break:break-all;">
                        Or copy this link: <%= meetLink %>
                    </p>
                    <% } %>

                        <div class="note">
                            <strong>Reminder:</strong> Please be on time. If you need to reschedule, kindly reply to
                            this email at least 24 hours in advance.
                        </div>
            </div>
            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
            </div>
        </div>
    </div>
</body>

</html>