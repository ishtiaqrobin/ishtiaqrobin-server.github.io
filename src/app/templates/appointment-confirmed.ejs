<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Appointment Confirmed - Ishtiaq Robin</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f4f5;
            color: #18181b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 48px 20px;
        }

        .container {
            max-width: 560px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e4e4e7;
        }

        /* ── Top bar ── */
        .header {
            background-color: #111116;
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-brand {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .header-badge {
            display: inline-block;
            padding: 4px 12px;
            margin-left: 8px;
            background-color: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        /* ── Content ── */
        .content {
            padding: 40px 32px;
        }

        .eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 10px;
        }

        .title {
            font-size: 22px;
            font-weight: 700;
            color: #111116;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .greeting {
            font-size: 14px;
            color: #71717a;
            margin-bottom: 24px;
        }

        /* ── Details card ── */
        .details {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 28px;
        }

        .detail-row {
            display: table;
            width: 100%;
            padding: 13px 18px;
            border-bottom: 1px solid #f4f4f5;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .detail-label {
            display: table-cell;
            font-size: 12px;
            font-weight: 600;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            width: 90px;
            vertical-align: middle;
        }

        .detail-value {
            display: table-cell;
            font-size: 14px;
            font-weight: 500;
            color: #18181b;
            vertical-align: middle;
        }

        /* ── CTA button ── */
        .cta {
            text-align: center;
            margin: 28px 0 10px;
        }

        .cta a {
            display: inline-block;
            padding: 13px 32px;
            background-color: #111116;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 999px;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.01em;
        }

        .cta-link {
            text-align: center;
            font-size: 12px;
            color: #a1a1aa;
            margin-top: 10px;
            word-break: break-all;
        }

        /* ── Note ── */
        .note {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-left: 3px solid #f59e0b;
            border-radius: 10px;
            padding: 14px 16px;
            font-size: 12px;
            color: #71717a;
            margin-top: 24px;
            line-height: 1.6;
        }

        .note strong {
            color: #b45309;
        }

        /* ── Footer ── */
        .footer {
            padding: 20px 32px 28px;
            border-top: 1px solid #f4f4f5;
            text-align: center;
            font-size: 12px;
            color: #a1a1aa;
        }

        @media only screen and (max-width: 600px) {
            .wrapper {
                padding: 0;
            }

            .container {
                border-radius: 0;
                border-left: none;
                border-right: none;
            }

            .header,
            .content {
                padding-left: 20px;
                padding-right: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">

            <div class="header">
                <span class="header-brand">Ishtiaq Robin</span>
                <span class="header-badge">Confirmed</span>
            </div>

            <div class="content">
                <p class="eyebrow">Appointment</p>
                <h1 class="title">Your Appointment is Confirmed</h1>
                <p class="greeting">
                    Hi <strong>
                        <%= name %>
                    </strong>, great news! Your appointment with
                    <strong>Ishtiaq Robin</strong> has been confirmed. Here are your booking details:
                </p>

                <div class="details">
                    <div class="detail-row">
                        <span class="detail-label">Topic</span>
                        <span class="detail-value">
                            <%= topic %>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Date</span>
                        <span class="detail-value">
                            <%= date %>
                        </span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Time</span>
                        <span class="detail-value">
                            <%= time %>
                        </span>
                    </div>
                    <% if (typeof adminNote !=='undefined' && adminNote) { %>
                        <div class="detail-row">
                            <span class="detail-label">Note</span>
                            <span class="detail-value">
                                <%= adminNote %>
                            </span>
                        </div>
                        <% } %>
                </div>

                <% if (typeof meetLink !=='undefined' && meetLink) { %>
                    <div class="cta">
                        <a href="<%= meetLink %>" target="_blank">Join Meeting</a>
                    </div>
                    <p class="cta-link">
                        <%= meetLink %>
                    </p>
                    <% } %>

                        <div class="note">
                            <strong>Reminder:</strong> Please be on time. If you need to reschedule, kindly reply to
                            this email at least 24 hours in advance.
                        </div>
            </div>

            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
            </div>

        </div>
    </div>
</body>

</html>