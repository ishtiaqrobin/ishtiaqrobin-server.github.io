<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Comment is Live - Ishtiaq Robin's Blog</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f4f5;
            color: #18181b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 48px 20px;
        }

        .container {
            max-width: 560px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e4e4e7;
        }

        /* ── Top bar ── */
        .header {
            background-color: #111116;
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-brand {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .header-badge {
            display: inline-block;
            padding: 4px 12px;
            margin-left: 8px;
            background-color: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        /* ── Content ── */
        .content {
            padding: 40px 32px;
        }

        .eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 10px;
        }

        .title {
            font-size: 22px;
            font-weight: 700;
            color: #111116;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .greeting {
            font-size: 14px;
            color: #71717a;
            margin-bottom: 20px;
        }

        /* ── Blog title ── */
        .blog-ref {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-radius: 12px;
            padding: 14px 16px;
            margin-bottom: 16px;
        }

        .blog-ref-label {
            font-size: 11px;
            font-weight: 600;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            white-space: nowrap;
            padding-top: 2px;
        }

        .blog-ref-title {
            font-size: 14px;
            font-weight: 600;
            color: #18181b;
        }

        /* ── Comment quote box ── */
        .comment-box {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-left: 3px solid #10b981;
            border-radius: 12px;
            padding: 16px 18px;
            margin-bottom: 28px;
            font-size: 14px;
            font-style: italic;
            color: #3f3f46;
            line-height: 1.7;
        }

        /* ── CTA button ── */
        .cta {
            text-align: center;
            margin-bottom: 24px;
        }

        .cta a {
            display: inline-block;
            padding: 13px 32px;
            background-color: #111116;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 999px;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.01em;
        }

        .sub-note {
            font-size: 13px;
            color: #a1a1aa;
            text-align: center;
        }

        /* ── Footer ── */
        .footer {
            padding: 20px 32px 28px;
            border-top: 1px solid #f4f4f5;
            text-align: center;
            font-size: 12px;
            color: #a1a1aa;
        }

        @media only screen and (max-width: 600px) {
            .wrapper {
                padding: 0;
            }

            .container {
                border-radius: 0;
                border-left: none;
                border-right: none;
            }

            .header,
            .content {
                padding-left: 20px;
                padding-right: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">

            <div class="header">
                <span class="header-brand">Ishtiaq Robin</span>
                <span class="header-badge">Comment Live</span>
            </div>

            <div class="content">
                <p class="eyebrow">Blog Activity</p>
                <h1 class="title">Your Comment is Live!</h1>
                <p class="greeting">
                    Hi <strong>
                        <%= name %>
                    </strong>, thanks for engaging with the blog!
                    Your comment has been approved and is now publicly visible on:
                </p>

                <div class="blog-ref">
                    <span class="blog-ref-label">Post</span>
                    <span class="blog-ref-title">
                        <%= blogTitle %>
                    </span>
                </div>

                <div class="comment-box">
                    &ldquo;<%= comment %>&rdquo;
                </div>

                <% if (typeof blogUrl !=='undefined' && blogUrl) { %>
                    <div class="cta">
                        <a href="<%= blogUrl %>" target="_blank">View Your Comment</a>
                    </div>
                    <% } %>

                        <p class="sub-note">
                            Feel free to keep the conversation going &mdash; reply to other comments or share the post
                            with your network!
                        </p>
            </div>

            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
            </div>

        </div>
    </div>
</body>

</html>