<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ishtiaq Robin Portfolio - Google Sign In</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f4f5;
            color: #18181b;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }

        /* ── Card ── */
        .card {
            background: #ffffff;
            border: 1px solid #e4e4e7;
            border-radius: 24px;
            padding: 48px 40px;
            max-width: 400px;
            width: 90%;
            text-align: center;
        }

        /* ── Spinner ── */
        .spinner-wrap {
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 28px;
        }

        .spinner {
            width: 48px;
            height: 48px;
            border: 3px solid #e4e4e7;
            border-top-color: #111116;
            border-radius: 50%;
            animation: spin 0.9s linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* ── Eyebrow + title ── */
        .eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 10px;
        }

        .title {
            font-size: 20px;
            font-weight: 700;
            color: #111116;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .message {
            font-size: 14px;
            color: #71717a;
            line-height: 1.6;
        }

        /* ── Brand footer ── */
        .brand {
            margin-top: 36px;
            font-size: 11px;
            font-weight: 600;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        /* ── Error state ── */
        .error-card {
            background: #ffffff;
            border: 1px solid #fecaca;
            border-radius: 24px;
            padding: 48px 40px;
            max-width: 400px;
            width: 90%;
            text-align: center;
        }

        .error-icon {
            font-size: 36px;
            margin-bottom: 20px;
        }

        .error-eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #ef4444;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 10px;
        }

        .error-title {
            font-size: 20px;
            font-weight: 700;
            color: #111116;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .error-message {
            font-size: 14px;
            color: #71717a;
            margin-bottom: 20px;
            line-height: 1.6;
        }

        .error-detail {
            background-color: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 10px;
            padding: 12px 14px;
            font-size: 12px;
            color: #991b1b;
            word-break: break-all;
            text-align: left;
            margin-bottom: 28px;
        }

        .retry-btn {
            display: inline-block;
            padding: 12px 28px;
            background-color: #111116;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 999px;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.01em;
        }
    </style>
</head>

<body>
    <div id="content" class="card">
        <div class="spinner-wrap">
            <div class="spinner"></div>
        </div>
        <p class="eyebrow">Google Sign In</p>
        <h1 class="title">Redirecting...</h1>
        <p class="message">Please wait while we connect your Google account.</p>
        <p class="brand">Ishtiaq Robin Portfolio</p>
    </div>

    <script>
        (async () => {
            const contentDiv = document.getElementById('content');

            try {
                const res = await fetch("<%= betterAuthUrl %>/api/auth/sign-in/social", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    credentials: "include",
                    body: JSON.stringify({
                        provider: "google",
                        callbackURL: "<%= callbackURL %>",
                    }),
                });

                const data = await res.json();

                if (data.url) {
                    window.location.href = data.url;
                } else {
                    showError(data.error || "Unknown error occurred during social sign-in.");
                }
            } catch (error) {
                showError(error.message);
            }

            function showError(message) {
                contentDiv.className = 'error-card';
                contentDiv.innerHTML = `
                    <div class="error-icon">&#9888;&#65039;</div>
                    <p class="error-eyebrow">Sign-in Failed</p>
                    <h1 class="error-title">Something went wrong</h1>
                    <p class="error-message">We couldn't connect to Google at this moment. Please try again.</p>
                    <div class="error-detail">Error: ${message}</div>
                    <a href="/" class="retry-btn">Back to Home</a>
                `;
            }
        })();
    </script>
</body>

</html>