<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ishtiaq Robin Portfolio - OTP Verification</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f4f5;
            color: #18181b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 48px 20px;
        }

        .container {
            max-width: 520px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e4e4e7;
        }

        /* ── Top bar ── */
        .header {
            background-color: #111116;
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-brand {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .header-badge {
            display: inline-block;
            padding: 4px 12px;
            margin-left: 8px;
            background-color: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        /* ── Content ── */
        .content {
            padding: 40px 32px;
        }

        .eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 10px;
        }

        .title {
            font-size: 22px;
            font-weight: 700;
            color: #111116;
            letter-spacing: -0.02em;
            margin-bottom: 8px;
        }

        .greeting {
            font-size: 14px;
            color: #71717a;
            margin-bottom: 0;
        }

        /* ── OTP box ── */
        .otp-box {
            background-color: #f4f4f5;
            border: 1px solid #e4e4e7;
            border-radius: 16px;
            padding: 32px 24px;
            margin: 28px 0;
            text-align: center;
        }

        .otp-label {
            font-size: 11px;
            font-weight: 600;
            color: #a1a1aa;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 16px;
        }

        .otp-code {
            font-size: 44px;
            font-weight: 800;
            letter-spacing: 14px;
            color: #111116;
            line-height: 1;
            font-variant-numeric: tabular-nums;
        }

        .otp-expiry {
            margin-top: 16px;
            font-size: 13px;
            color: #a1a1aa;
        }

        .otp-expiry strong {
            color: #71717a;
        }

        /* ── Divider ── */
        .divider {
            height: 1px;
            background-color: #f4f4f5;
            margin: 28px 0;
        }

        /* ── Warning note ── */
        .warning {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-left: 3px solid #ef4444;
            border-radius: 10px;
            padding: 14px 16px;
            font-size: 12px;
            color: #71717a;
            line-height: 1.6;
        }

        .warning strong {
            color: #ef4444;
        }

        /* ── Footer ── */
        .footer {
            padding: 20px 32px 28px;
            border-top: 1px solid #f4f4f5;
            text-align: center;
            font-size: 12px;
            color: #a1a1aa;
        }

        @media only screen and (max-width: 600px) {
            .wrapper {
                padding: 0;
            }

            .container {
                border-radius: 0;
                border-left: none;
                border-right: none;
            }

            .header,
            .content {
                padding-left: 20px;
                padding-right: 20px;
            }

            .otp-code {
                font-size: 36px;
                letter-spacing: 10px;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">

            <div class="header">
                <span class="header-brand">Ishtiaq Robin</span>
                <span class="header-badge">Verification</span>
            </div>

            <div class="content">
                <p class="eyebrow">Email Verification</p>
                <h1 class="title">Verify Your Email</h1>
                <p class="greeting">
                    Hello, <strong>
                        <%= name %>
                    </strong>! Use the code below to complete your verification.
                </p>

                <div class="otp-box">
                    <p class="otp-label">Your verification code</p>
                    <p class="otp-code">
                        <%= otp %>
                    </p>
                    <p class="otp-expiry">Expires in <strong>5 minutes</strong></p>
                </div>

                <div class="divider"></div>

                <div class="warning">
                    <strong>Security Note:</strong> If you didn't request this code, you can safely ignore this email.
                    Someone might have typed your email address by mistake.
                </div>
            </div>

            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
            </div>

        </div>
    </div>
</body>

</html>