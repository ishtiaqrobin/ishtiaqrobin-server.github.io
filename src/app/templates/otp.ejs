<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ishtiaq Robin Portfolio - OTP Verification</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8fafc;
            color: #1e293b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 40px 20px;
        }

        .container {
            max-width: 500px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
        }

        .header {
            background: linear-gradient(135deg, #7c3aed 0%, #6d28d9 100%);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }

        .logo {
            font-size: 28px;
            font-weight: 800;
            letter-spacing: -0.025em;
            margin: 0;
            text-transform: uppercase;
        }

        .content {
            padding: 40px 30px;
            text-align: center;
        }

        .title {
            font-size: 22px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .greeting {
            font-size: 16px;
            color: #64748b;
            margin-bottom: 24px;
        }

        .otp-container {
            background-color: #f5f3ff;
            border: 2px dashed #7c3aed;
            padding: 24px;
            margin: 32px 0;
            border-radius: 12px;
        }

        .otp-code {
            font-size: 42px;
            font-weight: 800;
            letter-spacing: 12px;
            color: #7c3aed;
            margin: 0;
            line-height: 1;
        }

        .expiry-info {
            color: #64748b;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }

        .divider {
            height: 1px;
            background-color: #e2e8f0;
            margin: 32px 0;
        }

        .footer {
            padding: 0 30px 40px;
            text-align: center;
            font-size: 13px;
            color: #94a3b8;
        }

        .warning {
            color: #94a3b8;
            font-size: 12px;
            margin-top: 16px;
            padding: 12px;
            background-color: #f8fafc;
            border-radius: 8px;
            border-left: 4px solid #ef4444;
            text-align: left;
        }

        .support-link {
            color: #7c3aed;
            text-decoration: none;
            font-weight: 500;
        }

        @media only screen and (max-width: 600px) {
            .wrapper {
                padding: 0;
            }

            .container {
                border-radius: 0;
                border: none;
                box-shadow: none;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1 class="logo">Ishtiaq Robin Portfolio</h1>
            </div>
            <div class="content">
                <h2 class="title">Verify Your Email</h2>
                <p class="greeting">Hello, <strong>
                        <%= name %>
                    </strong>! Use the code below to complete your verification.</p>

                <div class="otp-container">
                    <p class="otp-code">
                        <%= otp %>
                    </p>
                </div>

                <p class="expiry-info">
                    <span>This code will expire in <strong>2 minutes</strong></span>
                </p>

                <div class="divider"></div>

                <div class="warning">
                    <strong>Security Note:</strong> If you didn't request this code, you can safely ignore this email.
                    Someone might have typed your
                    email address by mistake.
                </div>
            </div>
            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
                <p>Empowering education through technology.</p>
            </div>
        </div>
    </div>
</body>

</html>