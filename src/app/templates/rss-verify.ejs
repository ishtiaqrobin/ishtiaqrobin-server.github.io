<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Your Subscription - Ishtiaq Robin's Blog</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8fafc;
            color: #1e293b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 40px 20px;
        }

        .container {
            max-width: 560px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
        }

        .header {
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            padding: 40px 30px;
            text-align: center;
            color: white;
        }

        .header h1 {
            margin: 0;
            font-size: 26px;
            font-weight: 800;
        }

        .header p {
            margin: 8px 0 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .content {
            padding: 36px 30px;
            text-align: center;
        }

        .content p {
            font-size: 15px;
            color: #334155;
            margin: 0 0 18px;
        }

        .cta {
            margin: 28px 0;
        }

        .cta a {
            display: inline-block;
            padding: 15px 38px;
            background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
            color: #fff !important;
            text-decoration: none;
            border-radius: 10px;
            font-weight: 700;
            font-size: 15px;
            letter-spacing: 0.3px;
        }

        .link-fallback {
            font-size: 12px;
            color: #64748b;
            word-break: break-all;
            background-color: #f1f5f9;
            padding: 12px;
            border-radius: 8px;
            margin-top: 16px;
        }

        .note {
            background-color: #f8fafc;
            border-left: 4px solid #cbd5e1;
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 12px;
            color: #64748b;
            text-align: left;
            margin-top: 24px;
        }

        .footer {
            padding: 20px 30px 32px;
            text-align: center;
            font-size: 12px;
            color: #94a3b8;
            border-top: 1px solid #e2e8f0;
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">
            <div class="header">
                <h1>📡 Almost There!</h1>
                <p>Confirm your RSS subscription</p>
            </div>
            <div class="content">
                <p>Hi there 👋</p>
                <p>
                    Thanks for subscribing to <strong>
                        <%= blogTitle %>
                    </strong>!
                    Please confirm your email address by clicking the button below to start receiving new post
                    notifications.
                </p>

                <div class="cta">
                    <a href="<%= verifyUrl %>" target="_blank">Confirm Subscription</a>
                </div>

                <div class="link-fallback">
                    Or copy & paste this link in your browser:<br />
                    <%= verifyUrl %>
                </div>

                <div class="note">
                    <strong>Didn't subscribe?</strong> You can safely ignore this email — no subscription will be
                    created without your confirmation.
                </div>
            </div>
            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
            </div>
        </div>
    </div>
</body>

</html>