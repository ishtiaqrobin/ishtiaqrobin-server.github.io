<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirm Your Subscription - Ishtiaq Robin's Blog</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #f4f4f5;
            color: #18181b;
            line-height: 1.6;
        }

        .wrapper {
            padding: 48px 20px;
        }

        .container {
            max-width: 540px;
            margin: 0 auto;
            background: #ffffff;
            border-radius: 24px;
            overflow: hidden;
            border: 1px solid #e4e4e7;
        }

        /* ── Top bar ── */
        .header {
            background-color: #111116;
            padding: 28px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-brand {
            font-size: 15px;
            font-weight: 700;
            color: #ffffff;
            letter-spacing: -0.01em;
        }

        .header-badge {
            display: inline-block;
            padding: 4px 12px;
            margin-left: 8px;
            background-color: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 999px;
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            letter-spacing: 0.06em;
            text-transform: uppercase;
        }

        /* ── Content ── */
        .content {
            padding: 40px 32px;
            text-align: center;
        }

        .eyebrow {
            font-size: 11px;
            font-weight: 600;
            color: #10b981;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 10px;
        }

        .title {
            font-size: 22px;
            font-weight: 700;
            color: #111116;
            letter-spacing: -0.02em;
            margin-bottom: 12px;
        }

        .body-text {
            font-size: 14px;
            color: #71717a;
            margin-bottom: 32px;
            line-height: 1.7;
        }

        .body-text strong {
            color: #18181b;
        }

        /* ── CTA button ── */
        .cta {
            margin-bottom: 20px;
        }

        .cta a {
            display: inline-block;
            padding: 13px 36px;
            background-color: #111116;
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 999px;
            font-weight: 600;
            font-size: 14px;
            letter-spacing: 0.01em;
        }

        /* ── Fallback link ── */
        .link-fallback {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 12px;
            color: #a1a1aa;
            word-break: break-all;
            text-align: left;
            margin-bottom: 24px;
        }

        .link-fallback span {
            display: block;
            margin-bottom: 4px;
            font-weight: 600;
            color: #71717a;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-size: 11px;
        }

        /* ── Note ── */
        .note {
            background-color: #fafafa;
            border: 1px solid #e4e4e7;
            border-left: 3px solid #e4e4e7;
            border-radius: 10px;
            padding: 14px 16px;
            font-size: 12px;
            color: #a1a1aa;
            text-align: left;
            line-height: 1.6;
        }

        .note strong {
            color: #71717a;
        }

        /* ── Footer ── */
        .footer {
            padding: 20px 32px 28px;
            border-top: 1px solid #f4f4f5;
            text-align: center;
            font-size: 12px;
            color: #a1a1aa;
        }

        @media only screen and (max-width: 600px) {
            .wrapper {
                padding: 0;
            }

            .container {
                border-radius: 0;
                border-left: none;
                border-right: none;
            }

            .header,
            .content {
                padding-left: 20px;
                padding-right: 20px;
            }
        }
    </style>
</head>

<body>
    <div class="wrapper">
        <div class="container">

            <div class="header">
                <span class="header-brand">Ishtiaq Robin</span>
                <span class="header-badge">Confirm Email</span>
            </div>

            <div class="content">
                <p class="eyebrow">RSS Subscription</p>
                <h1 class="title">Almost There!</h1>
                <p class="body-text">
                    Hi there! Thanks for subscribing to <strong>
                        <%= blogTitle %>
                    </strong>.
                    Please confirm your email address by clicking the button below to start
                    receiving new post notifications.
                </p>

                <div class="cta">
                    <a href="<%= verifyUrl %>" target="_blank">Confirm Subscription</a>
                </div>

                <div class="link-fallback">
                    <span>Or copy this link</span>
                    <%= verifyUrl %>
                </div>

                <div class="note">
                    <strong>Didn't subscribe?</strong> You can safely ignore this email &mdash;
                    no subscription will be created without your confirmation.
                </div>
            </div>

            <div class="footer">
                <p>&copy; 2026 Ishtiaq Robin Portfolio. All rights reserved.</p>
            </div>

        </div>
    </div>
</body>

</html>